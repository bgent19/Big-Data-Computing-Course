# =============================================================================
# SD411 Big Data Computing — common.env
# SINGLE SOURCE OF TRUTH for every lab stack on the student VM.
#
# How this is used:
#   scripts/sync_env.sh stamps a copy of THIS file into each labN/ directory
#   as labN/.env . Docker Compose auto-reads .env for ${VAR} substitution, so
#   every lab compose file references these names instead of hardcoding tags,
#   credentials, ports, or sizing. Change a value here, re-run sync_env.sh,
#   and all labs move in lockstep.
#
# Rule: NO lab compose file may hardcode an image tag, credential, bucket
#       name, or worker size. If you find one, lift it into this file.
# =============================================================================

# ---- Container images (pinned) ---------------------------------------------
# Spark: official Apache image. Bitnami was removed from Docker Hub Aug 2025;
# any bitnami/spark tag now 404s. Labs 1-3 compose files still say bitnami and
# MUST be migrated to this var (see CHANGELOG_entry_vm_base.md, finding F1).
SPARK_IMAGE=apache/spark:3.5.3-python3

# Hadoop (Lab 1 HDFS namenode/datanode).
HADOOP_IMAGE=apache/hadoop:3.3.6

# MinIO server + mc client.
# !!! PLACEHOLDER TAGS — reconcile against lab0/docker-compose.yml and confirm
# !!! on Docker Hub before publishing (CHANGELOG finding F2). A tag drift here
# !!! silently breaks persisted Week 1 MinIO volumes across labs.
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
MC_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z

# Optional locally-built Spark image with the USNA root CA baked into the Java
# truststore (see Dockerfile.spark-usna). Leave SPARK_IMAGE pointed at the
# upstream image unless you adopt the derived-image path course-wide.
SPARK_USNA_IMAGE=sd411/spark-usna:3.5.3

# ---- MinIO / S3A credentials and layout ------------------------------------
# These MUST be identical across all labs or persisted volumes break.
MINIO_ROOT_USER=sd411admin
MINIO_ROOT_PASSWORD=sd411password
S3_BUCKET=sd411
S3_LANDING_BUCKET=landing
S3_ENDPOINT=http://minio:9000

# ---- Cross-lab fact-table contract -----------------------------------------
# lab06 (Partitioning) WRITES this prefix; lab07 (Joins) READS it. They must
# never disagree, so the path lives here and both labs resolve it from the
# stamped .env. If lab06's writer moves, change it HERE, not in either lab.
# Full path is s3a://${S3_BUCKET}/${FACT_PREFIX}
FACT_PREFIX=fact/pitches

# ---- S3A connector JARs (host-fetched; see scripts/download_jars.sh) -------
# Versions Hadoop 3.3.4 was built against. Mismatches surface as
# NoSuchMethodError at RUNTIME, not load time. Move these together.
HADOOP_AWS_VERSION=3.3.4
AWS_SDK_BUNDLE_VERSION=1.12.262

# ---- Worker sizing (course-wide; NOT a per-student knob) -------------------
# Assumes >=8 GB student VMs. If the issued VMs are 4 GB, drop WORKER_MEM
# course-wide here (e.g. 1500m) rather than editing individual labs.
# See CHANGELOG finding F3 — confirm issued VM specs before term.
WORKER_MEM=2g
WORKER_CORES=2
SPARK_DAEMON_MEM=512m

# ---- Host ports ------------------------------------------------------------
# Every lab reuses these, so only ONE sd411 stack can run at a time.
# scripts/sd411_down_all.sh clears a stale stack before switching labs.
PORT_SPARK_MASTER_UI=8080
PORT_SPARK_WORKER_UI=8081
PORT_SPARK_MASTER=7077
PORT_DRIVER_UI=4040
PORT_DRIVER_UI_ALT=4041
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001
PORT_HDFS_NN_UI=9870

# ---- Trust / network workarounds (USNA TLS interception) -------------------
# The institutional proxy MITMs TLS, so the system CA bundle is the only
# trust store that already contains the USNA root. pybaseball (Python) reads
# this; Java reads its own cacerts (handled by the host-fetched JARs or the
# derived image). See scripts/fix_trust_stores.sh.
SYSTEM_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# ---- Shared on-VM paths ----------------------------------------------------
# Provisioned once; labs read the seed and JARs from these stable locations.
SD411_HOME=/opt/sd411
SD411_DATA=/opt/sd411/data
SD411_JARS=/opt/sd411/jars
SD411_REPO=/opt/sd411/repo
SEED_CSV=statcast_2025.csv

# ---- Dataset sanity floors (enforced by seed + verify scripts) -------------
SEED_MIN_MB=100
SEED_MIN_ROWS=600000
SEED_SEASON_START=2025-03-27
SEED_SEASON_END=2025-09-28
